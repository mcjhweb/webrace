          alt="上一頁" src="../icon/lasr%20page%20autumn.png"><img style="width: 195px; height: 195px;"
          alt="下一頁" src="../icon/next%20page%20Autumn.png"></a><br>
      <a href="../../summer/school%20life/school%20life.html"><img style="width: 173px; height: 158px;"
          alt="上一季" src="../icon/last%20season%20autumn%20.png"></a><a href="../../winter/activity/activity.html"><img
          style="width: 185px; height: 168px;" alt="下一季" src="../icon/next%20season%20autumn.png"></a>
    </footer>
  </body>
</html>
